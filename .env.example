# ════════════════════════════════════════════════════════════════════
#  Cat's Bot — Configuración de entorno (.env.example)
#  Copia este archivo como .env y rellena los valores.
#  Genera claves secretas con: python3 -c "import secrets; print(secrets.token_hex(32))"
# ════════════════════════════════════════════════════════════════════

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Token del bot — https://discord.com/developers/applications
TOKEN=

# ID de la aplicación (Client ID del bot)
DISCORD_CLIENT_ID=

# Client Secret — Panel de OAuth2 en developer portal
DISCORD_CLIENT_SECRET=

# ── Panel Web ─────────────────────────────────────────────────────────────────
# URL pública del frontend del panel (sin slash final)
DASHBOARD_URL=http://localhost:8080
# El panel se sirve en /panel y la API en /api usando el mismo dominio/tunel.

# URL pública del backend API (sin slash final)
# En producción: https://api.tudominio.com
# En desarrollo con Cloudflared: https://xxxx.trycloudflare.com
API_BASE_URL=http://localhost:8080
# Callback Discord: <API_BASE_URL>/api/auth/callback

# Puerto del servidor FastAPI (default: 8080)
# API_PORT=8080

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Clave secreta para firmar JWT (mínimo 32 chars)
# Genera: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Clave maestra para acceso admin sin OAuth2 (opcional, déjala vacía para desactivar)
MASTER_ADMIN_KEY=

# ── Base de datos ─────────────────────────────────────────────────────────────
# Opciones: sqlite | postgresql | mariadb
# Por defecto: sqlite (no requiere configuración adicional)
DB_TYPE=sqlite

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Descomenta y completa si DB_TYPE=postgresql
#
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_db

# ── MariaDB / MySQL ───────────────────────────────────────────────────────────
# Descomenta y completa si DB_TYPE=mariadb
#
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=bot_user
# DB_PASSWORD=contraseña_segura
# DB_NAME=bot_es_db

# ── Inteligencia Artificial (Google Gemini / Gemma) ───────────────────────────
# API Key fallback — Obtenerla en https://aistudio.google.com/app/apikey (gratis).
# Esta key se usa solo cuando un servidor NO tiene una key del pool asignada.
# Para producción usa el pool multi-key desde el dashboard /admin/ai-keys.
GEMINI_API_KEY=

# Pool multi-key:
#   • Cada API key puede cubrir hasta 2 guilds (AI_KEY_MAX_GUILDS_PER_KEY = 2).
#   • La asignación guild→key vive en la tabla ``ai_guild_keys`` y se gestiona
#     desde el dashboard /admin/ai-keys (master admin).
#   • Si en producción tienes N servidores, registra ceil(N/2) keys para no
#     compartir cuota agresivamente.

# Prompt global del sistema (puede sobreescribirse por servidor desde el Dashboard).
# AI_SYSTEM_PROMPT=Eres un asistente amigable llamado Cat's Bot. Responde siempre en español.

# ── Modelos del free tier vigente (referencia, configurables por guild en dashboard) ─
# UNICAMENTE Gemma 4 (servido por la API de Gemini). Soporta multimodal
# (imágenes/audio/video/PDF) y Google Search grounding igual que Gemini.
# Cuotas: RPM (peticiones/min) · TPM (tokens/min) · RPD (peticiones/día)
#
#   gemma-4-26b-it    15 RPM · ilimitado TPM · 1.5K RPD   (default)
#   gemma-4-31b-it    15 RPM · ilimitado TPM · 1.5K RPD   (XL razonamiento)
#
# Cualquier modelo distinto guardado en DB (legados Gemini, Gemma 2/3) se
# migra al default automáticamente al arrancar el cog IA.

# ── Rate Limiting IA ──────────────────────────────────────────────────────────
# Ajusta a la cuota más restrictiva del modelo elegido. Default conservador:
# AI_RATE_CAPACITY=5       # Requests máximos por periodo (default: 5)
# AI_RATE_PERIOD=60        # Duración del periodo en segundos (default: 60)

# ── Concurrencia IA ───────────────────────────────────────────────────────────
# AI_CONCURRENCY=2         # Llamadas paralelas a la API (default: 2)
# AI_QUEUE_SIZE=64         # Tamaño máximo de la cola (default: 64)
# AI_MIN_USER_INTERVAL=4.0 # Segundos entre consultas del mismo usuario (default: 4.0)

# ── Radio / Música ────────────────────────────────────────────────────────────
# (Sin configuración adicional requerida — se configura desde el Dashboard)

# ── CORS ─────────────────────────────────────────────────────────────────────
# Orígenes permitidos (separados por coma si son múltiples)
# ALLOWED_ORIGINS=http://localhost:5173,https://panel.tudominio.com

# ── Logs ─────────────────────────────────────────────────────────────────────
# Nivel de log: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
